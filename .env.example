# Required for production — change this!
DESHIFRO_SECRET_KEY=change-me-to-a-random-string

# VirusTotal API key (free tier: https://www.virustotal.com/gui/join-us)
VT_API_KEY=

# Ghidra install directory (optional, for deep decompilation)
GHIDRA_INSTALL_DIR=

# AI features — Ollama (local LLM, free, fully private)
# 1. Install Ollama: https://ollama.com/download
# 2. Pull a model: ollama pull llama3.1:8b
# 3. Ollama runs automatically on localhost:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
